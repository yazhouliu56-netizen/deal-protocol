# ─────────────────────────────────────────
# Deal Protocol — 环境变量说明范本
# 复制本文件为 .env.local 并填写实际值
# ─────────────────────────────────────────

# Supabase（必填）
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# 服务端 Supabase Service Role Key（仅用于 API Route / Cron）
# {Supabase 项目 Settings → API → service_role (secret)}
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# 站点 URL（Supabase Auth 回调 & 支付回调）
# 生产: https://deal-protocol-phi.vercel.app
# 本地: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ───── LLM / AI ─────
# AI Provider 选择: deepseek | gemini | openai（默认 deepseek）
AI_PROVIDER=deepseek

# DeepSeek API Key（国内首选，零延迟零阻断）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DeepSeek API 端点（官方: https://api.deepseek.com/v1）
# 备选免费节点: https://api.siliconflow.cn/v1（硅基流动）
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Gemini API Key（用于 AI 匹配与协议生成，海外备选）
GEMINI_API_KEY=your_gemini_api_key

# GitHub Models token（用于 AI Chat 功能，海外备选）
OPENCODE_GITHUB_TOKEN=your_github_token

# ───── Stripe ─────
# 自动识别 Live/Test: sk_live_ → 生产, sk_test_ → 沙箱
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ───── Payment Channel Configuration ─────
# alipay | stripe | mock
PAYMENT_CHANNEL=alipay

# ───── Alipay（选填）─────
ALIPAY_APP_ID=2021000000000000
ALIPAY_PRIVATE_KEY=your_alipay_private_key_pem
ALIPAY_PUBLIC_KEY=your_alipay_public_key_pem
ALIPAY_GATEWAY=https://openapi-sandbox.dl.alipaydev.com/gateway.do

# ───── WeChat Pay（选填）─────
WECHAT_APP_ID=your_wechat_app_id
WECHAT_MCH_ID=your_mch_id
WECHAT_API_KEY_V3=your_api_v3_key
WECHAT_PRIVATE_KEY=your_wechat_private_key
WECHAT_SERIAL_NO=your_cert_serial_no

# ───── Payment ─────
# 异步支付结果通知地址（须使用生产域名）
PAYMENT_NOTIFY_URL=https://deal-protocol-phi.vercel.app
# 生产环境请设为 false
PAYMENT_SANDBOX=false

# ───── Push 通知（选填）─────
REDIS_URL=redis://default:password@host:6379
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
FCM_SERVER_KEY=your_fcm_server_key

# ───── SOS 应急（选填）─────
SMS_API_URL=https://your-sms-api.com/send
SMS_API_KEY=your_sms_api_key
PUSH_API_URL=https://your-push-api.com/send
PUSH_API_KEY=your_push_api_key

# ───── 实名认证（选填）─────
REAL_NAME_API_KEY=your_real_name_api_key

# ───── Cron 鉴权 ─────
CRON_SECRET=your_cron_secret

# ───── PII 加密 ─────
PII_ENCRYPTION_KEY=your_32_char_hex_key

# ───── 内部遥测（选填）─────
NEXT_PUBLIC_METRICS_BACKEND=console

# ───── Vercel 自动注入（无需手动填写）─────
# VERCEL=1
# VERCEL_ENV=production
# VERCEL_URL=...
# NEXT_PUBLIC_VERCEL_URL=...
