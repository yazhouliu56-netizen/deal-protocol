# ─────────────────────────────────────────
# Deal Protocol — 环境变量说明范本
# 复制本文件为 .env.local 并填写实际值
# 各变量后的 {Vercel 域} 为生产环境值来源
# ─────────────────────────────────────────

# Supabase（必填）
# {Vercel 域: your-project 的 Vercel 项目域}
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
# {Vercel 域: Supabase 项目 Settings → API → anon/public}
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# 服务端 Supabase Service Role Key（仅用于 API Route / Cron）
# {Vercel 域: Supabase 项目 Settings → API → service_role (secret)}
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# 站点 URL（用于 Supabase Auth 回调 & 支付回调）
# {Vercel 域: Vercel 分配给正式域, 如 https://deal-protocol.vercel.app}
# {本地: http://localhost:3000}
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# LLM API（阶段一用 mock 可不填）
# GitHub Models (免费)
GITHUB_TOKEN=your_github_token
# 或 OpenAI / Qwen / DeepSeek
LLM_API_KEY=your_api_key
LLM_BASE_URL=https://models.inference.ai.azure.com
LLM_MODEL=gpt-4o-mini

# Stripe（选填）
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Alipay（选填）
ALIPAY_APP_ID=your_alipay_app_id
ALIPAY_PRIVATE_KEY=your_rsa_private_key
ALIPAY_PUBLIC_KEY=your_alipay_public_key

# WeChat Pay（选填）
WECHAT_APP_ID=your_wechat_app_id
WECHAT_MCH_ID=your_mch_id
WECHAT_API_KEY_V3=your_api_v3_key
WECHAT_PRIVATE_KEY=your_wechat_private_key
WECHAT_SERIAL_NO=your_cert_serial_no

# Payment（通用）
# {Vercel 域: 生产环境域名, 与 NEXT_PUBLIC_SITE_URL 一致}
PAYMENT_NOTIFY_URL=https://your-domain.com
PAYMENT_SANDBOX=true

# ───── Vercel 自动注入（无需手动填写） ─────
# VERCEL=1                  # Vercel 平台标识
# VERCEL_ENV=production     # production / preview / development
# VERCEL_URL=...            # 自动分配的域名
# NEXT_PUBLIC_VERCEL_URL=   # 客户端可用域名
